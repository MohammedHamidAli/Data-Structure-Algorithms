#include <iostream>
#include <string>
#include <vector>

using namespace std;

void naiveSearch(string text, string pattern) {
    int n = text.length();
    int m = pattern.length();

    cout << "Searching for '" << pattern << "' in '" << text << "'..." << endl;
    bool found = false;

    // Slide the pattern over text one by one
    for (int i = 0; i <= n - m; i++) {
        int j;

        // For current index i, check for pattern match
        for (j = 0; j < m; j++) {
            if (text[i + j] != pattern[j]) {
                break; // Mismatch found, break internal loop
            }
        }

        // If j reached m, then pattern found at current index i
        if (j == m) {
            cout << "Pattern found at index " << i << endl;
            found = true;
        }
    }

    if (!found) {
        cout << "Pattern not found in the given text." << endl;
    }
}

int main() {
    string text = "AABAACAADAABAAABAA";
    string pattern = "AABA";
    
    naiveSearch(text, pattern);
    
    return 0;
}
